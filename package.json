{
  "name": "@aabuhijleh/bgg-cli",
  "version": "0.4.0",
  "description": "Manage your BoardGameGeek collection from a Bun CLI",
  "author": {
    "name": "aabuhijleh",
    "email": "aabuhijleh.dev@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aabuhijleh/bgg-cli.git"
  },
  "bugs": {
    "url": "https://github.com/aabuhijleh/bgg-cli/issues"
  },
  "homepage": "https://github.com/aabuhijleh/bgg-cli#readme",
  "type": "module",
  "private": false,
  "bin": {
    "bgg": "bin/bgg"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "collection": "bun src/app/collection.ts",
    "check": "biome check",
    "install-hooks": "lefthook install",
    "prepublishOnly": "bun run check && bun run typecheck && bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "lefthook": "^2.1.6"
  }
}
